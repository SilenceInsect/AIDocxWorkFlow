{
  "version": 1,
  "terminalAllowlist": [
    "git status",
    "git add",
    "git commit",
    "git diff",
    "git log",
    "git branch",
    "git checkout",
    "git stash",
    "git fetch",
    "git pull",
    "python *",
    "python3 *",
    "pip install *",
    "pip3 install *",
    "npm install *",
    "npm run *",
    "node *",
    "ls",
    "dir",
    "cat",
    "type",
    "mkdir",
    "rmdir",
    "cp",
    "xcopy",
    "mv",
    "move",
    "open",
    "start",
    "cd *",
    "cd",
    "pwd",
    "echo *",
    "node --version",
    "python --version",
    "python3 --version",
    "pip list",
    "pip show *"
  ],
  "mcpTools": {
    "aidocx-workflow": {
      "tools": "*",
      "autoRun": true
    }
  },
  "autoRun": {
    "terminal": {
      "defaultBehavior": "allow",
      "allowDangerous": true,
      "instructions": "Allow all python/node/npm scripts. Allow git except force push. Allow file read/write."
    },
    "mcp": {
      "defaultBehavior": "allow",
      "instructions": "Allow all MCP tools without confirmation."
    }
  }
}