#!/usr/bin/env bash
# post-commit hook: 公有仓库提交后自动同步到私有仓库
# 触发时机: commit 完成后

set -e

# 检测是否推送到 upstream（公有仓库）
# 如果当前分支是 main 且 upstream 存在，则同步到 origin（私有仓库）
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$CURRENT_BRANCH" = "main" ]; then
    # 检查是否有 upstream remote
    if git remote get-url upstream >/dev/null 2>&1; then
        echo "[sync-hook] Syncing to private repo (origin)..."
        # 推送到私有仓库（origin）
        git push origin main --quiet 2>/dev/null || {
            echo "[sync-hook] Warning: Failed to push to origin, but commit succeeded."
        }
    fi
fi

exit 0
