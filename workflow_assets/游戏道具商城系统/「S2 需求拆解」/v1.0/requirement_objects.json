        {"id": "OBJ-004-FP-6", "name": "新手礼包购买限制", "category": "购买限制", "boundary": "首次购买成功/重复购买第2次", "test_type": "正向+异常", "priority": "P1"},
        {"id": "OBJ-004-FP-7", "name": "折扣叠加规则计算", "category": "折扣计算", "boundary": "[待确认]min最优/叠加/不可叠加", "test_type": "正向+异常", "priority": "P0"},
        {"id": "OBJ-004-FP-8", "name": "多促销时间重叠处理", "category": "促销冲突", "boundary": "无重叠/时间重叠/优先级不同", "test_type": "异常", "priority": "P2"},
        {"id": "OBJ-004-FP-9", "name": "促销配置热更新", "category": "配置更新", "boundary": "生效中修改/结束前修改/批量修改", "test_type": "边界", "priority": "P2"}
      ]
