  "requirement_objects": [
    {
      "id": "OBJ-001",
      "name": "购买流程",
      "story_id": "BIZ-PURCHASE",
      "primary_module": "BIZ",
      "secondary_modules": ["UI", "AUX", "LINK"],
      "object_states": [
        {"state": "待确认", "trigger": "玩家点击购买", "result": "展示确认弹窗"},
        {"state": "余额不足", "trigger": "余额 < 所需金额", "result": "购买按钮禁用"},
        {"state": "数量超限", "trigger": "数量 > 99", "result": "前端拦截"},
        {"state": "支付中", "trigger": "扣款发起", "result": "显示支付状态"},
        {"state": "支付成功", "trigger": "扣款完成", "result": "道具到账+邮件"},
        {"state": "支付失败", "trigger": "扣款失败", "result": "余额回滚"},
        {"state": "重复提交", "trigger": "支付中再次点击", "result": "前端禁用"}
      ],
      "interaction_forms": [
        "界面操作: 购买按钮 → 确认弹窗 → 数量选择 → 确认支付",
        "API调用: POST /api/purchase/confirm → POST /api/payment/deduct → POST /api/item/deliver",
        "系统事件: 支付成功 → 道具到账 → 邮件发送 → 订单创建"
      ],
      "business_logic": "玩家ID+道具ID+数量+支付方式 → 校验登录态 → 校验道具可购买 → 校验余额 → 锁定汇率 → 计算价格(含折扣满减) → 扣款 → 道具到账 → 创建订单 → 异步邮件",
      "exception_boundaries": [
        {"scenario": "道具已下架", "handling": "拒绝购买"},
        {"scenario": "余额刚好等于所需", "handling": "允许购买，余额归零"},
        {"scenario": "并发购买限量道具", "handling": "超卖防护，仅一人成功"},
        {"scenario": "数量为0或负数", "handling": "前端拦截+后端兜底拒绝"},
        {"scenario": "到账失败", "handling": "回滚扣款"}
      ],
      "exception_interactions": [
        {"type": "支付超时(>500ms)", "handling": "返回错误，提示重试"},
        {"type": "网络断开", "handling": "禁用按钮，显示网络异常"},
        {"type": "回调丢失", "handling": "后端轮询，5分钟无确认则退款"},
        {"type": "渠道支付失败", "handling": "展示渠道错误信息"}
      ],
      "module_inference": {"primary": ["BIZ"], "secondary": ["UI", "AUX", "LINK", "LOG", "SPECIAL"]},
      "logs_and_tracking": [
        {"event": "purchase.initiated", "trigger": "点击购买", "fields": ["player_id", "item_id", "quantity", "timestamp"]},
        {"event": "purchase.price_calculated", "trigger": "价格计算完成", "fields": ["item_id", "original_price", "final_price", "discount_detail"]},
        {"event": "purchase.payment_started", "trigger": "扣款发起", "fields": ["order_id", "player_id", "amount", "payment_method"]},
        {"event": "purchase.completed", "trigger": "购买成功", "fields": ["order_id", "player_id", "item_id", "quantity", "final_price"]},
        {"event": "purchase.failed", "trigger": "购买失败", "fields": ["order_id", "player_id", "failure_reason", "error_code"]},
        {"event": "item.delivered", "trigger": "道具到账", "fields": ["player_id", "item_id", "quantity", "order_id"]},
        {"event": "email.notification_sent", "trigger": "邮件发送", "fields": ["order_id", "player_id", "email_status"]}
      ],
      "related_protocols": [
        {"name": "PurchaseService.CreateOrder", "caller": "前端", "receiver": "购买服务", "fields": ["player_id", "item_id", "quantity", "channel"]},
        {"name": "PaymentService.Deduct", "caller": "购买服务", "receiver": "支付服务", "fields": ["player_id", "amount", "currency", "order_id"]},
        {"name": "ItemService.Deliver", "caller": "购买服务", "receiver": "道具服务", "fields": ["player_id", "item_id", "quantity"]},
        {"name": "OrderService.Create", "caller": "购买服务", "receiver": "订单服务", "fields": ["order_id", "all order fields"]},
        {"name": "EmailService.Send", "caller": "购买服务", "receiver": "邮件服务(异步)", "fields": ["player_id", "subject", "body", "order_id"]}
      ],
      "feature_points": [
        {"id": "OBJ-001-FP-1", "name": "购买确认弹窗展示", "category": "购买流程", "boundary": "含折扣/不含折扣/数量=1/数量>1", "test_type": "正向+边界", "priority": "P0"},
        {"id": "OBJ-001-FP-2", "name": "余额不足拦截", "category": "余额校验", "boundary": "余额=0/<价格/=价格/>价格", "test_type": "边界", "priority": "P0"},
        {"id": "OBJ-001-FP-3", "name": "数量范围校验(1-99)", "category": "数量校验", "boundary": "=0/=1/=99/=100/=-1", "test_type": "边界+异常", "priority": "P1"},
        {"id": "OBJ-001-FP-4", "name": "道具到账时效", "category": "到账时效", "boundary": "<1秒/<3秒/>3秒", "test_type": "正向+异常", "priority": "P0"},
        {"id": "OBJ-001-FP-5", "name": "超时与重试", "category": "异常处理", "boundary": "超时=500ms/重试1-3次/幂等", "test_type": "异常", "priority": "P1"},
        {"id": "OBJ-001-FP-6", "name": "支付幂等性", "category": "幂等校验", "boundary": "重复支付1次/3次/不同订单同金额", "test_type": "异常", "priority": "P0"},
        {"id": "OBJ-001-FP-7", "name": "并发超卖防护", "category": "并发控制", "boundary": "顺序购买/并发抢购限量/超卖临界点", "test_type": "异常", "priority": "P1"},
        {"id": "OBJ-001-FP-8", "name": "邮件通知字段完整性", "category": "邮件通知", "boundary": "字段完整/字段缺失/发送失败", "test_type": "正向+异常", "priority": "P1"}
      ]
    },
    {
      "id": "OBJ-002",
      "name": "道具数据",
      "story_id": "UI-SHOP",
      "primary_module": "AUX",
      "secondary_modules": ["UI", "CONFIG"],
      "object_states": [
        {"state": "正常展示", "trigger": "已上架未过期", "result": "正常展示"},
        {"state": "折扣中", "trigger": "限时折扣生效", "result": "折扣标签+划线原价"},
        {"state": "已下架", "trigger": "管理员下架", "result": "不展示"},
        {"state": "缓存中", "trigger": "数据来自缓存", "result": "无网络请求"},
        {"state": "VIP专属", "trigger": "道具标记为VIP专属", "result": "仅VIP可见"}
      ],
      "interaction_forms": [
        "界面操作: 浏览首页 → 点击分类/搜索 → 查看列表 → 点击详情",
        "API调用: GET /api/items, GET /api/items/{id}",
        "系统事件: 配置变更 → 缓存失效 → hot标签变更 → 首页刷新"
      ],
      "business_logic": "玩家ID+分类ID+页码+关键词 → 检查缓存 → 筛选分类/搜索 → VIP可见性过滤 → 折扣计算 → 分页返回",
      "exception_boundaries": [
        {"scenario": "道具数量<20(最后一页)", "handling": "正常返回"},
        {"scenario": "搜索关键词=1字符", "handling": "前端拦截，至少2字符"},
        {"scenario": "搜索结果为空", "handling": "空列表+空状态"},
        {"scenario": "热门道具=0个", "handling": "推荐区隐藏"},
        {"scenario": "热门道具>10个", "handling": "截取前10"}
      ],
      "exception_interactions": [
        {"type": "缓存失效时大量请求", "handling": "限流/排队加载"},
        {"type": "配置表读取超时", "handling": "返回缓存旧数据或返回错误"},
        {"type": "hot标签变更后前端未刷新", "handling": "强制刷新"}
      ],
      "module_inference": {"primary": ["UI", "AUX"], "secondary": ["CONFIG"]},
      "logs_and_tracking": [
        {"event": "item.viewed", "trigger": "查看详情", "fields": ["player_id", "item_id", "timestamp"]},
        {"event": "item.search", "trigger": "搜索", "fields": ["player_id", "keyword", "result_count"]},
        {"event": "cache.hit", "trigger": "缓存命中", "fields": ["item_id", "cache_age_seconds"]},
        {"event": "cache.miss", "trigger": "缓存未命中", "fields": ["item_id", "reload_reason"]},
        {"event": "hot_tag.changed", "trigger": "hot标签变更", "fields": ["item_id", "old_tag", "new_tag", "operator"]}
      ],
      "related_protocols": [
        {"name": "ItemService.GetList", "caller": "前端", "receiver": "后端道具服务", "fields": ["category_id", "page", "page_size", "player_id"]},
        {"name": "ItemService.GetDetail", "caller": "前端", "receiver": "后端道具服务", "fields": ["item_id", "player_id"]},
        {"name": "ConfigService.GetItemConfig", "caller": "道具服务", "receiver": "配置服务", "fields": ["item_id"]}
      ],
      "feature_points": [
        {"id": "OBJ-002-FP-1", "name": "道具列表分页展示", "category": "分页展示", "boundary": "每页20个/最后一页<20/第N页/空分类", "test_type": "正向+边界", "priority": "P0"},
        {"id": "OBJ-002-FP-2", "name": "热门道具展示(前10)", "category": "热门推荐", "boundary": "=0/1-9/=10/>10个", "test_type": "正向+边界", "priority": "P1"},
        {"id": "OBJ-002-FP-3", "name": "道具缓存刷新(5分钟)", "category": "缓存机制", "boundary": "<5分钟/=5分钟/>5分钟/配置变更", "test_type": "边界", "priority": "P1"},
        {"id": "OBJ-002-FP-4", "name": "折扣标签展示", "category": "折扣展示", "boundary": "无折扣/限时/满减/VIP/多重叠加", "test_type": "正向", "priority": "P0"},
        {"id": "OBJ-002-FP-5", "name": "道具搜索(模糊匹配)", "category": "搜索", "boundary": "1字符/2字符/>2字符/精确/模糊/无结果", "test_type": "正向+边界+异常", "priority": "P1"},
        {"id": "OBJ-002-FP-6", "name": "VIP专属道具可见性过滤", "category": "权限控制", "boundary": "普通/VIP等级不足/等级足够/非VIP", "test_type": "边界+异常", "priority": "P0"}
      ]
    },
    {
      "id": "OBJ-003",
      "name": "VIP配置",
      "story_id": "CONFIG-VIP",
      "primary_module": "CONFIG",
      "secondary_modules": ["BIZ"],
      "object_states": [
        {"state": "永久有效", "trigger": "无时效配置", "result": "持续有效"},
        {"state": "定时考核", "trigger": "当时效配置", "result": "到期判定"},
        {"state": "变更中", "trigger": "策划修改配置表", "result": "实时生效"},
        {"state": "等级不足", "trigger": "等级<道具要求", "result": "不可见不可买"}
      ],
      "interaction_forms": [
        "界面操作: 策划登录配置后台 → 编辑VIP规则 → 保存配置",
        "API调用: GET /api/vip/config, POST /api/vip/config",
        "系统事件: 配置变更 → 全服生效 → 玩家登录拉取配置"
      ],
      "business_logic": "策划编辑VIP规则 → 保存触发全服生效 → 玩家登录拉取配置 → 购买时计算折扣",
      "exception_boundaries": [
        {"scenario": "配置缺失", "handling": "使用默认折扣(不打折)"},
        {"scenario": "折扣比例>100%", "handling": "前端拦截+后端拒绝"},
        {"scenario": "解锁条件为空", "handling": "该等级不可解锁"},
        {"scenario": "满足多个条件", "handling": "第一个匹配条件为准"}
      ],
      "exception_interactions": [
        {"type": "配置保存失败", "handling": "提示失败，配置不更新"},
        {"type": "大量玩家同时在线", "handling": "异步下发"},
        {"type": "购买中途VIP升级", "handling": "本次以购买时等级为准"}
      ],
      "module_inference": {"primary": ["CONFIG", "BIZ"], "secondary": ["UI"]},
      "logs_and_tracking": [
