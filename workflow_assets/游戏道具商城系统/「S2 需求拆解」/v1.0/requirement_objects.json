        {"event": "vip.player.upgraded", "trigger": "升级", "fields": ["player_id", "old_level", "new_level"]},
        {"event": "vip.player.downgraded", "trigger": "降级", "fields": ["player_id", "old_level", "new_level"]},
        {"event": "vip.discount.applied", "trigger": "折扣应用", "fields": ["player_id", "vip_level", "original_price", "discounted_price"]}
      ],
      "related_protocols": [
        {"name": "VipService.GetConfig", "caller": "客户端", "receiver": "配置服务", "fields": []},
        {"name": "VipService.UpdateConfig", "caller": "配置后台", "receiver": "配置服务", "fields": ["vip_levels", "discounts", "conditions"]},
        {"name": "VipService.GetPlayerLevel", "caller": "购买服务", "receiver": "VIP服务", "fields": ["player_id"]},
        {"name": "VipService.CalculateDiscount", "caller": "购买服务", "receiver": "VIP服务", "fields": ["vip_level", "original_price"]}
      ],
      "feature_points": [
        {"id": "OBJ-003-FP-1", "name": "VIP折扣计算(VIP1/2/3)", "category": "折扣计算", "boundary": "VIP1=95折/VIP2=9折/VIP3=85折/非VIP", "test_type": "正向+边界", "priority": "P0"},
        {"id": "OBJ-003-FP-2", "name": "VIP解锁条件判定", "category": "权限判定", "boundary": "满足消费/在线时长/持有道具/不满足", "test_type": "正向+逆向", "priority": "P1"},
        {"id": "OBJ-003-FP-3", "name": "VIP配置实时生效", "category": "配置变更", "boundary": "折扣变更/条件变更/新增等级/删除等级", "test_type": "正向", "priority": "P1"},
        {"id": "OBJ-003-FP-4", "name": "VIP折扣实时应用", "category": "折扣应用", "boundary": "购买中途升级/配置变更时已有VIP", "test_type": "异常", "priority": "P1"},
        {"id": "OBJ-003-FP-5", "name": "折扣比例配置校验", "category": "配置校验", "boundary": "=0%/=50%/=100%/-10%/=150%", "test_type": "边界+异常", "priority": "P2"},
        {"id": "OBJ-003-FP-6", "name": "VIP等级时效处理", "category": "时效管理", "boundary": "[待确认]永久/30天/90天/到期当天/到期次日", "test_type": "边界", "priority": "P1"},
        {"id": "OBJ-003-FP-7", "name": "VIP专属道具可见性", "category": "权限过滤", "boundary": "[待确认]按最低等级/精确等级/等级范围", "test_type": "正向+逆向", "priority": "P0"},
        {"id": "OBJ-003-FP-8", "name": "配置表读取一致性", "category": "数据一致性", "boundary": "单服/多服/热更新中/回滚", "test_type": "异常", "priority": "P2"}
      ]
    },
    {
      "id": "OBJ-004",
      "name": "促销配置",
      "story_id": "CONFIG-DISCOUNT",
      "primary_module": "CONFIG",
      "secondary_modules": ["BIZ", "UI"],
      "object_states": [
        {"state": "未开始", "trigger": "时间<开始时间", "result": "不展示折扣"},
        {"state": "生效中", "trigger": "开始<=时间<=结束", "result": "折扣标签+折后价"},
        {"state": "已结束", "trigger": "时间>结束时间", "result": "恢复原价"},
        {"state": "配置变更", "trigger": "策划修改配置", "result": "实时生效"}
      ],
      "interaction_forms": [
        "界面操作: 策划配置后台 → 新建/编辑促销 → 设置时间折扣",
        "API调用: GET /api/promotion/active, POST /api/promotion",
        "系统事件: 促销开始/结束事件, 配置变更事件"
      ],
      "business_logic": "策划配置促销 → 保存 → 定时检查状态 → 生效促销展示折扣 → 购买时计算折扣 → 满减最后执行",
